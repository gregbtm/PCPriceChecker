# ── Required ──────────────────────────────────────────────────────────────────
# PricesAPI.io — free tier: 50,000 calls/month
# Sign up: https://pricesapi.io (no credit card required)
PRICES_API_KEY=your_pricesapi_key_here

# ── Keepa (Amazon UK price history) ───────────────────────────────────────────
# Free tier: 100 tokens/minute. Much more reliable than scraping CamelCamelCamel.
# Sign up: https://keepa.com/#!api
KEEPA_API_KEY=your_keepa_key_here

# ── AWIN (UK retailer product feeds) ──────────────────────────────────────────
# Covers Scan, Overclockers, Ebuyer, CCL, Currys, Amazon UK, Novatech, 300+ others.
# Free with a publisher account: https://www.awin.com/gb/publishers (approval ~1 week)
# Publisher ID and API key found in: awin.com/gb/publishers/profile/api-credentials
AWIN_PUBLISHER_ID=your_publisher_id_here
AWIN_API_KEY=your_awin_api_key_here

# ── Amazon Product Advertising API (PAAPI 5.0) ────────────────────────────────
# Official Amazon data — live prices, Prime status, product info.
# Free with Amazon Associates: https://affiliate-program.amazon.co.uk/
# Get credentials from: associates.amazon.co.uk → Tools → API Credentials
# Note: Amazon suspends accounts with no affiliate sales in 90 days.
AMAZON_ACCESS_KEY=your_access_key_here
AMAZON_SECRET_KEY=your_secret_key_here
AMAZON_ASSOCIATE_TAG=yourtag-21

# ── eBay Browse API ───────────────────────────────────────────────────────────
# Live eBay UK listings — new, used, and refurbished. Free: 5,000 calls/day.
# Instant approval — no review wait.
# Sign up: https://developer.ebay.com → Create App → Production keys
# AppID = EBAY_CLIENT_ID, CertID = EBAY_CLIENT_SECRET
EBAY_CLIENT_ID=your_app_id_here
EBAY_CLIENT_SECRET=your_cert_id_here

# ── Bing Search v7 (Microsoft Azure) ─────────────────────────────────────────
# Supplements PricesAPI — finds prices at UK retailers not covered by other sources.
# Also useful for discovering long-tail shops.
# Free tier: 1,000 calls/month. Then ~£0.003/call.
# Sign up: portal.azure.com → Create resource → search "Bing Search v7" → Create
#          → Keys and Endpoint → copy Key 1
# BING_API_KEY=your_bing_key_here

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Find review videos from Gamers Nexus, Hardware Unboxed, LTT, and more.
# Free tier: 10,000 units/day (1 search = 100 units → ~100 reviews/day free).
# Sign up: console.cloud.google.com → Create project → Enable "YouTube Data API v3"
#          → Credentials → API key
# YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Reddit API (read-only) ────────────────────────────────────────────────────
# r/buildapc recommendations and r/buildapcsales UK deals.
# Free — no rate limit for read-only client_credentials.
# Sign up: reddit.com/prefs/apps → Create App → type: script
# REDDIT_CLIENT_ID=your_app_id_here
# REDDIT_CLIENT_SECRET=your_app_secret_here

# ── Infrastructure ────────────────────────────────────────────────────────────
# SQLite database path. On cloud platforms with a persistent disk:
# DB_PATH=/var/data/pc-prices.db
# DB_PATH=

# Web dashboard port. Cloud platforms inject PORT automatically.
# WEB_PORT takes priority; falls back to PORT; then defaults to 3000.
# Set to 0 to disable the web UI when running as MCP-only.
# WEB_PORT=3000

# Background price refresh interval in minutes.
# Set this to auto-start the scheduler on first boot without needing to
# configure it via the web UI or MCP tool. Minimum: 1. Recommended: 60.
# SCHEDULER_INTERVAL_MINUTES=60
