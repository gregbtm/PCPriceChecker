# Required: PricesAPI.io key — free tier gives 50,000 calls/month
# Sign up at https://pricesapi.io (no credit card required)
PRICES_API_KEY=your_api_key_here

# Optional: override the SQLite database path (default: ./data/pc-prices.db)
# On cloud platforms with a persistent disk, point this at the mount:
# DB_PATH=/var/data/pc-prices.db

# Optional: web dashboard port.
# Cloud platforms (Render, Railway, Fly.io) inject PORT automatically.
# WEB_PORT takes priority; falls back to PORT; then defaults to 3000.
# Set to 0 to disable the web UI when running as MCP-only.
# WEB_PORT=3000
